includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6

    phpVersion: 80000

    paths:
        - hma-core.php
        - uninstall.php
        - src/

    excludePaths:
        - vendor/
        - node_modules/
        - tests/
        - assets/

    bootstrapFiles:
        - vendor/autoload.php
        - phpstan-bootstrap.php

    # Treat missing WordPress/WooCommerce functions as errors (caught by stubs above).
    treatPhpDocTypesAsCertain: false
