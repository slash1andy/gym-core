includes:
    - phar://phpstan.phar/conf/bleedingEdge.neon
    - vendor/szepeviktor/phpstan-wordpress/extension.neon
    - vendor/phpstan/phpstan-deprecation-rules/rules.neon

parameters:
    level: 7
    paths:
        - src
        - hma-ai-chat.php
        - uninstall.php
    excludePaths:
        - vendor
        - node_modules (?)
        - assets/build (?)
        - tests
    treatPhpDocTypesAsCertain: false

    bootstrapFiles:
        - phpstan-bootstrap.php

    ignoreErrors:
        # Missing-type signature checks. The maintainer originally opted out of
        # iterable value-type checking; restore that intent across the related
        # missingType identifiers rather than rewriting every method signature.
        -
            identifier: missingType.iterableValue
        -
            identifier: missingType.return
        # wp_ai_client_prompt() is a forthcoming WordPress 7.0 API. Call sites are
        # gated by function_exists() at runtime.
        - '#Function wp_ai_client_prompt not found#'
        # The plugin entry file (no namespace) bootstraps the plugin classes;
        # @internal here documents intent for external integrators, not a hard
        # cross-namespace boundary.
        -
            identifier: method.internal
            path: hma-ai-chat.php
        -
            identifier: staticMethod.internal
            path: hma-ai-chat.php
