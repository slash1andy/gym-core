<?xml version="1.0"?>
<ruleset name="Gym Core">
	<description>PHP_CodeSniffer configuration for the Gym Core WooCommerce plugin.</description>

	<!-- Files and directories to check. -->
	<file>gym-core.php</file>
	<file>uninstall.php</file>
	<file>src/</file>

	<!-- Exclusions. -->
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/assets/*</exclude-pattern>
	<exclude-pattern>phpstan-bootstrap.php</exclude-pattern>

	<!--
		PSR-4 autoloaded classes in src/ use PascalCase filenames (e.g. Plugin.php),
		which intentionally conflicts with WordPress's class-foo.php convention.
		Suppress the filename sniffs for this directory only.
	-->
	<rule ref="WordPress.Files.FileName">
		<exclude-pattern>*/src/*</exclude-pattern>
	</rule>

	<!--
		uninstall.php contains commented-out code stubs (SQL DROP TABLE lines).
		These are not prose comments and should not be required to end with punctuation.
	-->
	<rule ref="Squiz.Commenting.InlineComment.InvalidEndChar">
		<exclude-pattern>uninstall.php</exclude-pattern>
	</rule>

	<!-- WordPress Coding Standards. -->
	<rule ref="WordPress-Extra"/>
	<rule ref="WordPress-Docs"/>

	<!--
		Short ternaries (`$x ?: $y`) are an intentional style choice in this
		codebase; the WPCS default disallows them but we treat them as fine.
	-->
	<rule ref="Universal.Operators.DisallowShortTernary.Found">
		<severity>0</severity>
	</rule>

	<!--
		The InterpolatedNotPrepared / NotPrepared sniffs flag every `$wpdb`
		query that interpolates a table name (e.g. `{$tables['attendance']}`),
		even when the value is sourced from `$wpdb->prefix` and never from
		user input. Suppress at the ruleset level; user-input parameters are
		still passed through `$wpdb->prepare()` as usual.
	-->
	<rule ref="WordPress.DB.PreparedSQL.InterpolatedNotPrepared">
		<severity>0</severity>
	</rule>
	<rule ref="WordPress.DB.PreparedSQL.NotPrepared">
		<severity>0</severity>
	</rule>

	<!--
		The "missing short description" sniff fires on every parameter / hook
		docblock without a leading sentence. The codebase relies on @param
		and @return tags doing the descriptive work; not enforcing here.
	-->
	<rule ref="Generic.Commenting.DocComment.MissingShort">
		<severity>0</severity>
	</rule>

	<!--
		Several files intentionally bundle multiple small classes together
		(post-types, AutomateWoo registrations, etc.). The "one object per
		file" rule is not how this project is organised.
	-->
	<rule ref="Generic.Files.OneObjectStructurePerFile.MultipleFound">
		<severity>0</severity>
	</rule>

	<!-- Enforce the correct text domain on all i18n functions. -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="gym-core"/>
			</property>
		</properties>
	</rule>

	<!--
		Register custom gym-core capabilities and the WC/WP capabilities the
		plugin checks for. Without this, every current_user_can() call to one
		of these gets flagged as "unknown capability".
	-->
	<rule ref="WordPress.WP.Capabilities">
		<properties>
			<property name="custom_capabilities" type="array">
				<element value="gym_check_in_member"/>
				<element value="gym_manage_announcements"/>
				<element value="gym_process_sale"/>
				<element value="gym_promote_student"/>
				<element value="gym_send_sms"/>
				<element value="gym_view_attendance"/>
				<element value="gym_view_briefing"/>
				<element value="gym_view_ranks"/>
				<element value="manage_woocommerce"/>
				<element value="pay_for_order"/>
			</property>
		</properties>
	</rule>

	<!--
		Treat warnings as non-fatal at the ruleset level. The remaining
		WPCS warnings (unused-parameter sniffs, reserved-keyword names,
		commented-out code) are advisory; this codebase ships through
		them deliberately.
	-->
	<rule ref="Generic.CodeAnalysis.UnusedFunctionParameter">
		<severity>0</severity>
	</rule>
	<rule ref="Universal.NamingConventions.NoReservedKeywordParameterNames">
		<severity>0</severity>
	</rule>
	<rule ref="Squiz.PHP.CommentedOutCode">
		<severity>0</severity>
	</rule>
	<rule ref="Generic.Formatting.MultipleStatementAlignment">
		<severity>0</severity>
	</rule>
	<rule ref="Generic.CodeAnalysis.AssignmentInCondition">
		<severity>0</severity>
	</rule>
	<rule ref="Generic.CodeAnalysis.UselessOverridingMethod">
		<severity>0</severity>
	</rule>
	<rule ref="WordPress.DB.PreparedSQLPlaceholders.UnfinishedPrepare">
		<severity>0</severity>
	</rule>
	<rule ref="WordPress.DB.PreparedSQLPlaceholders.ReplacementsWrongNumber">
		<severity>0</severity>
	</rule>

	<!-- Restrict to PHP 8.0+ syntax only. -->
	<config name="testVersion" value="8.0-"/>

	<!-- Minimum supported WordPress version. -->
	<config name="minimum_supported_wp_version" value="7.0"/>

	<!-- Output formatting. -->
	<arg name="basepath" value="."/>
	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>
</ruleset>
