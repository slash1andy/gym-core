{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "860px",
      "wideSize": "1280px"
    },
    "color": {
      "palette": [
        { "slug": "black", "color": "#000000", "name": "Black" },
        { "slug": "royal-blue", "color": "#0032A0", "name": "Royal Blue" },
        { "slug": "cool-gray", "color": "#75787B", "name": "Cool Gray" },
        { "slug": "white", "color": "#FFFFFF", "name": "White" },
        { "slug": "blue-hover", "color": "#0041CC", "name": "Blue Hover" },
        { "slug": "gray-light", "color": "#F5F5F7", "name": "Light Gray" },
        { "slug": "gray-100", "color": "#E5E5E7", "name": "Gray 100" },
        { "slug": "gray-800", "color": "#2A2A2A", "name": "Gray 800" },
        { "slug": "gray-900", "color": "#1A1A1A", "name": "Gray 900" },
        { "slug": "ink",   "color": "#0A0A0A", "name": "Ink" },
        { "slug": "paper", "color": "#F6F4EE", "name": "Paper" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Barlow Condensed', 'Arial Narrow', sans-serif",
          "slug": "barlow-condensed",
          "name": "Barlow Condensed"
        },
        {
          "fontFamily": "'Inter', 'Helvetica Neue', Arial, sans-serif",
          "slug": "inter",
          "name": "Inter"
        },
        {
          "fontFamily": "'Fraunces', ui-serif, Georgia, serif",
          "slug": "fraunces",
          "name": "Fraunces"
        }
      ],
      "fontSizes": [
        { "slug": "small", "size": "0.875rem", "name": "Small" },
        { "slug": "medium", "size": "1rem", "name": "Medium" },
        { "slug": "large", "size": "1.25rem", "name": "Large" },
        { "slug": "x-large", "size": "1.75rem", "name": "Extra Large" },
        { "slug": "xx-large", "size": "2.25rem", "name": "2X Large" },
        { "slug": "huge", "size": "clamp(2.75rem, 5vw, 4rem)", "name": "Huge" }
      ]
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingSizes": [
        { "slug": "10", "size": "0.5rem", "name": "1" },
        { "slug": "20", "size": "1rem", "name": "2" },
        { "slug": "30", "size": "1.5rem", "name": "3" },
        { "slug": "40", "size": "2rem", "name": "4" },
        { "slug": "50", "size": "3rem", "name": "5" },
        { "slug": "60", "size": "4rem", "name": "6" },
        { "slug": "70", "size": "5rem", "name": "7" },
        { "slug": "80", "size": "7rem", "name": "8" }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#000000"
    },
    "typography": {
      "fontFamily": "'Inter', 'Helvetica Neue', Arial, sans-serif",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "'Barlow Condensed', 'Arial Narrow', sans-serif",
          "fontWeight": "700",
          "lineHeight": "1.1",
          "textTransform": "uppercase",
          "letterSpacing": "0.02em"
        },
        "color": {
          "text": "#000000"
        }
      },
      "link": {
        "color": {
          "text": "#0032A0"
        },
        ":hover": {
          "color": {
            "text": "#0041CC"
          }
        }
      },
      "button": {
        "typography": {
          "fontFamily": "'Barlow Condensed', 'Arial Narrow', sans-serif",
          "fontSize": "0.875rem",
          "fontWeight": "600",
          "letterSpacing": "0.1em",
          "textTransform": "uppercase"
        },
        "color": {
          "background": "#0032A0",
          "text": "#FFFFFF"
        },
        "border": {
          "radius": "4px"
        },
        ":hover": {
          "color": {
            "background": "#0041CC",
            "text": "#FFFFFF"
          }
        }
      }
    },
    "blocks": {
      "core/navigation": {
        "typography": {
          "fontSize": "0.8125rem",
          "fontWeight": "500",
          "letterSpacing": "0.15em",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "#FFFFFF"
        }
      },
      "core/site-title": {
        "typography": {
          "fontFamily": "'Barlow Condensed', 'Arial Narrow', sans-serif",
          "fontWeight": "800",
          "fontSize": "1.5rem",
          "letterSpacing": "0.02em",
          "textTransform": "uppercase"
        },
        "color": {
          "text": "#FFFFFF"
        },
        "elements": {
          "link": {
            "color": {
              "text": "#FFFFFF"
            },
            ":hover": {
              "color": {
                "text": "#0032A0"
              }
            }
          }
        }
      }
    }
  },
  "templateParts": [
    { "name": "header", "title": "Header", "area": "header" },
    { "name": "footer", "title": "Footer", "area": "footer" }
  ]
}
