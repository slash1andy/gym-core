# Pressable Legacy Git Deploy — exclude non-deployable files
# Pressable rsyncs wp-content/ from repo root to the site
# Only wp-content/plugins/ and wp-content/themes/ should be synced

# Development & documentation (repo root)
docs/
scripts/
.claude/
.github/
CLAUDE.md
MILESTONES.md
README.md
LICENSE

# Build & config files
.gitignore
.deployignore
*.md
!wp-content/**/*.md

# Editor & OS
.vscode/
.idea/
.DS_Store
*.swp
*.swo
*~

# Dependencies & build tools (should not be deployed)
node_modules/
package.json
package-lock.json
composer.json
composer.lock
phpcs.xml
phpcs.xml.dist
phpstan.neon
phpunit.xml.dist
webpack.config.js
tsconfig.json

# Test files
tests/
*.test.js
*.test.php

# CI
.github/
codecov.yml

# Plugin-level dev files (vendor is built via composer install --no-dev)
wp-content/plugins/*/phpcs.xml.dist
wp-content/plugins/*/phpstan.neon
wp-content/plugins/*/phpstan-bootstrap.php
wp-content/plugins/*/phpunit.xml.dist
wp-content/plugins/*/.phpunit.result.cache
wp-content/plugins/*/PROJECT_BRIEF.md
wp-content/plugins/*/CLAUDE.md
